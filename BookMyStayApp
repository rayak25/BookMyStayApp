/**
 * HotelBookingApp now demonstrates fair handling of booking requests using a FIFO queue.
 * Guests submit booking requests which are stored in order of arrival.
 * Inventory is not modified at this stage.
 *
 * Author: User
 * Version: 1.0
 */
import java.util.*;

public class HotelBookingApp {

    public static void main(String[] args) {
        // Welcome message
        System.out.println("Welcome to the Hotel Booking System!");
        System.out.println("Application Name: Hotel Booking System");
        System.out.println("Version: 1.0\n");

        // Initialize room objects
        Room singleRoom = new SingleRoom(1, 20, 50.0);
        Room doubleRoom = new DoubleRoom(2, 35, 90.0);
        Room suiteRoom  = new SuiteRoom(3, 60, 200.0);

        // Initialize centralized inventory
        RoomInventory inventory = new RoomInventory();
        inventory.registerRoom(singleRoom, 5);
        inventory.registerRoom(doubleRoom, 3);
        inventory.registerRoom(suiteRoom, 2);

        // Initialize search service (read-only)
        SearchService searchService = new SearchService(inventory);

        // Guest performs a search
        List<Room> availableRooms = searchService.searchAvailableRooms(
                List.of(singleRoom, doubleRoom, suiteRoom));

        System.out.println("Available Rooms for Guests:\n");
        for (Room room : availableRooms) {
            System.out.println(room.getRoomType() + " - $" + room.getPrice() + " per night");
        }
        System.out.println();

        // ---------- Booking Request Intake ----------
        BookingRequestQueue bookingQueue = new BookingRequestQueue();

        // Guests submit booking requests (arrival order matters)
        bookingQueue.submitRequest(new Reservation("Alice", "Single Room", 2));
        bookingQueue.submitRequest(new Reservation("Bob", "Suite Room", 1));
        bookingQueue.submitRequest(new Reservation("Charlie", "Double Room", 1));

        // Display queued requests in order
        System.out.println("Current Booking Request Queue:\n");
        for (Reservation r : bookingQueue.getPendingRequests()) {
            System.out.println(r);
        }

        // Note: Inventory remains unchanged; no allocation is performed here
    }
}

/**
 * Represents a guest's intent to book a room.
 */
class Reservation {
    private String guestName;
    private String roomType;
    private int nights;

    public Reservation(String guestName, String roomType, int nights) {
        this.guestName = guestName;
        this.roomType = roomType;
        this.nights = nights;
    }

    public String getGuestName() { return guestName; }
    public String getRoomType() { return roomType; }
    public int getNights() { return nights; }

    @Override
    public String toString() {
        return guestName + " requests " + roomType + " for " + nights + " night(s)";
    }
}

/**
 * Manages booking requests in FIFO order.
 */
class BookingRequestQueue {
    private Queue<Reservation> requestQueue;

    public BookingRequestQueue() {
        requestQueue = new LinkedList<>();
    }

    /**
     * Submit a new booking request. Preserves arrival order.
     */
    public void submitRequest(Reservation reservation) {
        requestQueue.add(reservation);
    }

    /**
     * Returns all pending requests without modifying the queue.
     */
    public List<Reservation> getPendingRequests() {
        return new ArrayList<>(requestQueue);
    }

    /**
     * Retrieves and removes the next request from the queue for processing.
     */
    public Reservation processNextRequest() {
        return requestQueue.poll();
    }

    /**
     * Returns true if there are pending requests.
     */
    public boolean hasPendingRequests() {
        return !requestQueue.isEmpty();
    }
}

// ---------- Existing domain model and inventory classes ----------

abstract class Room {
    private int beds;
    private int size; // in square meters
    private double price; // per night

    public Room(int beds, int size, double price) {
        this.beds = beds;
        this.size = size;
        this.price = price;
    }

    public int getBeds() { return beds; }
    public int getSize() { return size; }
    public double getPrice() { return price; }
    public abstract String getRoomType();
}

class SingleRoom extends Room {
    public SingleRoom(int beds, int size, double price) { super(beds, size, price); }
    @Override public String getRoomType() { return "Single Room"; }
}

class DoubleRoom extends Room {
    public DoubleRoom(int beds, int size, double price) { super(beds, size, price); }
    @Override public String getRoomType() { return "Double Room"; }
}

class SuiteRoom extends Room {
    public SuiteRoom(int beds, int size, double price) { super(beds, size, price); }
    @Override public String getRoomType() { return "Suite Room"; }
}

class RoomInventory {
    private HashMap<String, Integer> availabilityMap;

    public RoomInventory() { availabilityMap = new HashMap<>(); }

    public void registerRoom(Room room, int count) {
        availabilityMap.put(room.getRoomType(), count);
    }

    public int getAvailability(String roomType) {
        return availabilityMap.getOrDefault(roomType, 0);
    }

    public boolean bookRoom(String roomType) {
        int available = availabilityMap.getOrDefault(roomType, 0);
        if (available > 0) {
            availabilityMap.put(roomType, available - 1);
            return true;
        } else {
            System.out.println("No " + roomType + " available for booking.");
            return false;
        }
    }

    public void addRooms(String roomType, int count) {
        int available = availabilityMap.getOrDefault(roomType, 0);
        availabilityMap.put(roomType, available + count);
    }
}

/**
 * Read-only service that allows guests to search for available rooms.
 */
class SearchService {
    private final RoomInventory inventory;

    public SearchService(RoomInventory inventory) {
        this.inventory = inventory;
    }

    public List<Room> searchAvailableRooms(List<Room> rooms) {
        List<Room> result = new ArrayList<>();
        for (Room room : rooms) {
            if (inventory.getAvailability(room.getRoomType()) > 0) {
                result.add(room);
            }
        }
        return result;
    }
}