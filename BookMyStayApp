/**
 * HotelBookingApp demonstrates object modeling, centralized inventory, and now
 * introduces a read-only SearchService to allow guests to view available rooms
 * without modifying system state.
 *
 * Author: User
 * Version: 1.0
 */
import java.util.HashMap;
import java.util.List;
import java.util.ArrayList;

public class HotelBookingApp {

    public static void main(String[] args) {
        // Welcome message
        System.out.println("Welcome to the Hotel Booking System!");
        System.out.println("Application Name: Hotel Booking System");
        System.out.println("Version: 1.0\n");

        // Initialize room objects
        Room singleRoom = new SingleRoom(1, 20, 50.0);
        Room doubleRoom = new DoubleRoom(2, 35, 90.0);
        Room suiteRoom  = new SuiteRoom(3, 60, 200.0);

        // Initialize centralized inventory
        RoomInventory inventory = new RoomInventory();
        inventory.registerRoom(singleRoom, 5);
        inventory.registerRoom(doubleRoom, 0); // intentionally zero to test filtering
        inventory.registerRoom(suiteRoom, 2);

        // Search service for guests
        SearchService searchService = new SearchService(inventory);

        // Perform a read-only search for available rooms
        List<Room> availableRooms = searchService.searchAvailableRooms(List.of(singleRoom, doubleRoom, suiteRoom));

        // Display search results
        System.out.println("Available Rooms for Guests:\n");
        for (Room room : availableRooms) {
            System.out.println(room.getRoomType() + ":");
            System.out.println("  Beds: " + room.getBeds());
            System.out.println("  Size: " + room.getSize() + " sqm");
            System.out.println("  Price per night: $" + room.getPrice());
            System.out.println("  Available: " + inventory.getAvailability(room.getRoomType()) + "\n");
        }

        // Note: Inventory remains unchanged; no bookings performed
    }
}

/**
 * Read-only service that allows guests to search for available rooms.
 * Does not modify inventory state.
 */
class SearchService {
    private final RoomInventory inventory;

    public SearchService(RoomInventory inventory) {
        this.inventory = inventory;
    }

    /**
     * Returns a list of rooms that have availability greater than zero.
     *
     * @param rooms list of all possible room objects
     * @return list of rooms with availability
     */
    public List<Room> searchAvailableRooms(List<Room> rooms) {
        List<Room> result = new ArrayList<>();
        for (Room room : rooms) {
            int available = inventory.getAvailability(room.getRoomType());
            if (available > 0) {
                result.add(room);
            }
        }
        return result;
    }
}

// ---------- Existing domain model and inventory classes ----------

abstract class Room {
    private int beds;
    private int size; // in square meters
    private double price; // per night

    public Room(int beds, int size, double price) {
        this.beds = beds;
        this.size = size;
        this.price = price;
    }

    public int getBeds() { return beds; }
    public int getSize() { return size; }
    public double getPrice() { return price; }
    public abstract String getRoomType();
}

class SingleRoom extends Room {
    public SingleRoom(int beds, int size, double price) { super(beds, size, price); }
    @Override public String getRoomType() { return "Single Room"; }
}

class DoubleRoom extends Room {
    public DoubleRoom(int beds, int size, double price) { super(beds, size, price); }
    @Override public String getRoomType() { return "Double Room"; }
}

class SuiteRoom extends Room {
    public SuiteRoom(int beds, int size, double price) { super(beds, size, price); }
    @Override public String getRoomType() { return "Suite Room"; }
}

class RoomInventory {
    private HashMap<String, Integer> availabilityMap;

    public RoomInventory() { availabilityMap = new HashMap<>(); }

    public void registerRoom(Room room, int count) {
        availabilityMap.put(room.getRoomType(), count);
    }

    public int getAvailability(String roomType) {
        return availabilityMap.getOrDefault(roomType, 0);
    }

    public boolean bookRoom(String roomType) {
        int available = availabilityMap.getOrDefault(roomType, 0);
        if (available > 0) {
            availabilityMap.put(roomType, available - 1);
            return true;
        } else {
            System.out.println("No " + roomType + " available for booking.");
            return false;
        }
    }

    public void addRooms(String roomType, int count) {
        int available = availabilityMap.getOrDefault(roomType, 0);
        availabilityMap.put(roomType, available + count);
    }
}